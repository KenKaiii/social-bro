{
  "name": "social-bro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "unset DATABASE_URL; next dev --turbopack 2>&1 | grep --line-buffered -v 'baseline-browser-mapping'",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "unset DATABASE_URL; prisma generate",
    "db:migrate": "unset DATABASE_URL; prisma migrate dev",
    "db:push": "unset DATABASE_URL; prisma db push",
    "db:studio": "unset DATABASE_URL; prisma studio",
    "db:seed": "unset DATABASE_URL; npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-table": "^8.21.3",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lru-cache": "^11.4.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "youtube-transcript-plus": "^2.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.9.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "picomatch": "^4.0.4",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.2",
    "typescript": "^5.9.3"
  }
}
